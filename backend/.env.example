# Backend environment variables (FastAPI)

APP_NAME=QG Exchange API
DEBUG=true

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

HOST=0.0.0.0
PORT=8000

# Database. SQLite by default (no setup). For PostgreSQL use e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/qgexchange
DATABASE_URL=sqlite:///./qgexchange.db

# JWT authentication. Use a long random string in production.
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: enables AI-assisted matching explanations. Falls back to the
# rule-based engine when empty.
OPENAI_API_KEY=
