# Backend environment variables (FastAPI)

APP_NAME=QG Exchange API
DEBUG=true

# Comma-separated list of allowed frontend origins for CORS.
# In production set this to your deployed frontend URL(s), e.g.
#   CORS_ORIGINS=https://your-app.vercel.app
# You can include multiple, comma-separated (no trailing slash).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

HOST=0.0.0.0
PORT=8000

# Database. SQLite by default (no setup). In production (Railway) the
# platform injects DATABASE_URL for the provisioned Postgres service.
# Both postgres:// and postgresql:// URLs are accepted and normalized to the
# psycopg 3 driver automatically. Example local Postgres:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/qgexchange
DATABASE_URL=sqlite:///./qgexchange.db

# JWT authentication. Use a long random string in production, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Seed categories + sample data on startup when the database is empty.
# Idempotent. Set to false once you have real production data you don't want
# the sample assets mixed into.
SEED_ON_STARTUP=true

# Optional: enables AI-assisted matching explanations. Falls back to the
# rule-based engine when empty.
OPENAI_API_KEY=
