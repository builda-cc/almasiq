# Frontend environment variables (Vite)
# Only variables prefixed with VITE_ are exposed to the client.

# Base URL the frontend uses to reach the backend API.
#
# Local dev: leave as "/api" to use the Vite proxy (see vite.config.ts).
#
# Production (Vercel): set to your deployed Railway backend URL INCLUDING the
# /api path segment, e.g.
#   VITE_API_BASE_URL=https://your-backend.up.railway.app/api
VITE_API_BASE_URL=/api
